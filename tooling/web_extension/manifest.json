{
  "manifest_version": 2,
  "name": "devtools-panels",
  "version": "1.0.0",
  

  "icons": {
    "48": "icons/star.png"
  },
  
  "permissions": [
      "<all_urls>"
  ],

  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["content/index.ts"]
    }
  ],
  
  "devtools_page": "devtool_page/page.html"

}
