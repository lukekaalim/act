{
  "manifest_version": 2,
  "name": "devtools-panels",
  "version": "1.0.0",
  
  "icons": {
    "48": "icons/star.png"
  },
  
  "permissions": [
      "<all_urls>"
  ],

  "background": {
    "scripts": ["dist/background.js"],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content.js"]
    }
  ],
  "devtools_page": "devtool_page.html"
}
